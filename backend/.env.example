OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini
AI_PROVIDER_DEFAULT=openrouter
STORAGE_MODE=mysql
BACKEND_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081
# Allow local network dev origins (e.g. http://192.168.x.x:8081). Defaults true outside production.
# Set to false in production if you want strict origin allowlisting only.
# BACKEND_ALLOW_PRIVATE_NETWORK_ORIGINS=true
# Optional API token protection for all /api routes
# BACKEND_AUTH_TOKEN=your_secure_token
# Trust X-Forwarded-For for client IP/rate-limiting only when behind a trusted reverse proxy.
# Leave false for direct/public server access to prevent client-side spoofing.
# BACKEND_TRUST_PROXY=false
# BACKEND_RATE_LIMIT_WINDOW_MS=60000
# BACKEND_RATE_LIMIT_MAX_REQUESTS=180
# Store campaign domain using normalized relational MySQL tables (recommended true).
# Set false to fallback to legacy JSON state blob storage for campaigns.
# MYSQL_NORMALIZED_CAMPAIGN_STORAGE=true
# BACKEND_LOG_REQUESTS=true
# BACKEND_INCIDENT_LOG_ENABLED=true
# BACKEND_INCIDENT_LOG_MAX_BYTES=5242880
# REFRESH_SIGNAL_HEARTBEAT_INTERVAL_MS=25000
# REFRESH_SIGNAL_CLIENT_STALE_MS=75000
# TELEMETRY_INCIDENT_DEFAULT_LIMIT=100
# TELEMETRY_INCIDENT_MAX_LIMIT=500
# TELEMETRY_REQUEST_EVENTS_LIMIT=1000
# For local JSON fallback (not MySQL): STORAGE_MODE=file
# MYSQL_URL=mysql://user:password@127.0.0.1:3306/creative_spark
# Or provide discrete MYSQL settings:
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_DATABASE=creative_spark
# MYSQL_USER=root
# MYSQL_PASSWORD=secret
# MYSQL_CONNECTION_LIMIT=10
# MYSQL_STATE_CHUNK_BYTES=524288
# MYSQL_STATE_INLINE_LIMIT_BYTES=524288
# OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_TIMEOUT_MS=45000
# OPENROUTER_MAX_RETRIES=2
# OPENROUTER_MAX_TOKENS=450
# OPENROUTER_APP_NAME=Creative Spark Backend
# OPENROUTER_APP_URL=http://127.0.0.1:8787
GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_ENDPOINT_BASE=https://generativelanguage.googleapis.com/v1beta/models
# GEMINI_TIMEOUT_MS=45000
# GEMINI_MAX_RETRIES=2
# GEMINI_MAX_OUTPUT_TOKENS=450
# External web search (used when includeExternal=true in chat/API)
# EXTERNAL_SEARCH_PROVIDER=auto
# EXTERNAL_SEARCH_TIMEOUT_MS=6000
# EXTERNAL_SEARCH_MAX_RETRIES=2
# EXTERNAL_SEARCH_MAX_RESULTS=4
# EXTERNAL_SEARCH_CACHE_TTL_MS=300000
# Google-compatible search via Serper:
# SERPER_API_KEY=your_serper_api_key
# SERPER_ENDPOINT=https://google.serper.dev/search
# Optional alternative provider:
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key
# BRAVE_SEARCH_ENDPOINT=https://api.search.brave.com/res/v1/web/search
